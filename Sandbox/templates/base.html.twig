		<!-- Quick Actions Bar Component -->
		<twig:QuickActionsBar />

		<!-- JavaScript Functions for QuickActionsBar -->
		<script>
			function showMobileDownload() {
				// Crear modal para descarga de app móvil
				const modal = document.createElement('div');
				modal.style.cssText = `
					position: fixed; top: 0; left: 0; width: 100%; height: 100%;
					background: rgba(0,0,0,0.5); display: flex; align-items: center; 
					justify-content: center; z-index: 10000;
				`;
				modal.innerHTML = `
					<div style="background: white; padding: 2rem; border-radius: 12px; max-width: 400px; text-align: center;">
						<h3 style="margin-bottom: 1rem; color: var(--primary-blue);">📱 Descarga DATA UEMOA</h3>
						<p style="margin-bottom: 1.5rem; color: #666;">Accede a los datos financieros desde tu móvil</p>
						<div style="display: flex; gap: 1rem; justify-content: center; margin-bottom: 1rem;">
							<a href="#" style="padding: 0.5rem 1rem; background: #000; color: white; text-decoration: none; border-radius: 8px;">
								📱 App Store
							</a>
							<a href="#" style="padding: 0.5rem 1rem; background: #01875f; color: white; text-decoration: none; border-radius: 8px;">
								🤖 Google Play
							</a>
						</div>
						<button onclick="this.parentElement.parentElement.remove()" style="background: #dc2626; color: white; border: none; padding: 0.5rem 1rem; border-radius: 6px; cursor: pointer;">
							Cerrar
						</button>
					</div>
				`;
				document.body.appendChild(modal);
				modal.onclick = (e) => { if (e.target === modal) modal.remove(); };
			}

			function showSupportChat() {
				// Crear modal de soporte
				const modal = document.createElement('div');
				modal.style.cssText = `
					position: fixed; top: 0; left: 0; width: 100%; height: 100%;
					background: rgba(0,0,0,0.5); display: flex; align-items: center; 
					justify-content: center; z-index: 10000;
				`;
				modal.innerHTML = `
					<div style="background: white; padding: 2rem; border-radius: 12px; max-width: 400px; text-align: center;">
						<h3 style="margin-bottom: 1rem; color: var(--primary-blue);">💬 Centro de Soporte</h3>
						<p style="margin-bottom: 1.5rem; color: #666;">¿En qué podemos ayudarte?</p>
						<div style="display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1rem;">
							<a href="mailto:support@datauemoa.com" style="padding: 0.75rem; background: var(--primary-blue); color: white; text-decoration: none; border-radius: 6px;">
								📧 Email: support@datauemoa.com
							</a>
							<a href="#" style="padding: 0.75rem; background: #059669; color: white; text-decoration: none; border-radius: 6px;">
								💬 Chat en vivo
							</a>
							<a href="/docs" style="padding: 0.75rem; background: #6b7280; color: white; text-decoration: none; border-radius: 6px;">
								📚 Documentación
							</a>
						</div>
						<button onclick="this.parentElement.parentElement.remove()" style="background: #dc2626; color: white; border: none; padding: 0.5rem 1rem; border-radius: 6px; cursor: pointer;">
							Cerrar
						</button>
					</div>
				`;
				document.body.appendChild(modal);
				modal.onclick = (e) => { if (e.target === modal) modal.remove(); };
			}

			function scrollToTop() {
				window.scrollTo({
					top: 0,
					behavior: 'smooth'
				});
			}

			// Auto-ocultar barra de acciones al hacer scroll hacia abajo
			let lastScrollTop = 0;
			window.addEventListener('scroll', function() {
				const quickActionsBar = document.querySelector('.QuickActionsBar');
				if (quickActionsBar) {
					const currentScroll = window.pageYOffset || document.documentElement.scrollTop;
					if (currentScroll > lastScrollTop && currentScroll > 200) {
						// Scrolling down
						quickActionsBar.style.opacity = '0.6';
					} else {
						// Scrolling up
						quickActionsBar.style.opacity = '1';
					}
					lastScrollTop = currentScroll <= 0 ? 0 : currentScroll;
				}
			});
		</script>
	</body>
</html>
